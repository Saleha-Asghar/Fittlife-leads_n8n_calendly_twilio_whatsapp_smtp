    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Detect channel and extract message\nlet channel = 'unknown';\nlet from = '';\nlet messageText = '';\nlet leadName = '';\n\n// WhatsApp via Twilio format\nif (body.SmsStatus || body.WaId) {\n  channel = 'whatsapp_twilio';\n  from = body.WaId || body.From || '';\n  messageText = body.Body || '';\n  leadName = body.ProfileName || 'Unknown';\n}\n// WhatsApp via Meta Cloud API format\nelse if (body.object === 'whatsapp_business_account') {\n  channel = 'whatsapp_meta';\n  const entry = body.entry?.[0];\n  const change = entry?.changes?.[0];\n  const msg = change?.value?.messages?.[0];\n  from = msg?.from || '';\n  messageText = msg?.text?.body || '';\n  const contacts = change?.value?.contacts?.[0];\n  leadName = contacts?.profile?.name || 'Unknown';\n}\n// Instagram DM via ManyChat webhook format\nelse if (body.channel === 'instagram' || body.platform === 'instagram') {\n  channel = 'instagram';\n  from = body.user_id || body.from || '';\n  messageText = body.text || body.message || '';\n  leadName = body.name || body.username || 'Unknown';\n}\n// Manual test format (for testing without any channel)\nelse if (body.test === true || body.manual === true) {\n  channel = 'manual_test';\n  from = body.phone || 'test_user';\n  messageText = body.message || '';\n  leadName = body.name || 'Test Lead';\n}\n// Generic fallback\nelse {\n  channel = 'unknown';\n  from = body.from || body.phone || 'unknown';\n  messageText = body.message || body.text || body.Body || '';\n  leadName = body.name || 'Unknown';\n}\n\n// Detect language\nconst urduPattern = /[\\u0600-\\u06FF]/;\nconst language = urduPattern.test(messageText) ? 'Urdu' : 'English';\n\nif (!messageText) {\n  return [{ json: { skip: true, reason: 'Empty message' } }];\n}\n\nreturn [{\n  json: {\n    skip: false,\n    channel,\n    from,\n    messageText,\n    leadName,\n    language,\n    timestamp: new Date().toLocaleString('en-PK', { \n      timeZone: 'Asia/Karachi' \n    })\n  }\n}];"
      },
