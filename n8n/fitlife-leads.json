    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst messageText = input.messageText || '';\n\n// Insert your actual Gemini API Key here\nconst GEMINI_API_KEY = 'GEMINI-API-KEY'; \n\n// The Brain: System Prompt forcing a structured JSON output\nconst systemPrompt = `You are an AI sales qualifier for a fitness coaching program called FitLife. \nAnalyze the user's message and return ONLY a valid JSON object with these exact keys:\n- \"intent\": Brief summary of their goal (e.g., \"weight loss\", \"pricing inquiry\").\n- \"budget\": Extracted budget, or \"unknown\" if not mentioned.\n- \"timeline\": Extracted timeline, or \"unknown\" if not mentioned.\n- \"leadScore\": Integer from 1 to 10 indicating buying readiness. BE STRICT. \n   - Generic statements (e.g., \"I want to lose weight\", \"hi\") = 3 to 5.\n   - Asking for details/pricing = 6 to 7. \n   - Explicitly stating they are ready to start right now or mentioning a specific budget = 8 to 10.\n- \"action\": Must be exactly one of: [\"nurture\", \"send_calendly\", \"hot_lead_call\"]. Use \"send_calendly\" for scores 7-8, \"hot_lead_call\" for scores 9-10, otherwise use \"nurture\".\n- \"replyMessage\": A natural, empathetic reply (1-2 sentences) matching their language. Either ask a qualifying question (nurture) or offer the next step.`;\n\nconst requestBody = {\n  system_instruction: { \n    parts: [{ text: systemPrompt }] \n  },\n  contents: [{ \n    role: 'user', \n    parts: [{ text: messageText }] \n  }],\n  generationConfig: { \n    response_mime_type: 'application/json' \n  }\n};\n\ntry {\n  // Make the call to Gemini using n8n's native approved helper\n  const response = await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + GEMINI_API_KEY,\n    headers: {\n      'Content-Type': 'application/json'\n    },\n    body: requestBody,\n    json: true\n  });\n\n  // Extract and parse the JSON from Gemini\n  const content = response.candidates[0].content.parts[0].text;\n  const parsedData = JSON.parse(content);\n  \n  return [{\n    json: {\n      ...input,\n      intent: parsedData.intent,\n      budget: parsedData.budget,\n      timeline: parsedData.timeline,\n      leadScore: parsedData.leadScore,\n      action: parsedData.action,\n      replyMessage: parsedData.replyMessage\n    }\n  }];\n\n} catch (e) {\n  // Fallback if the API fails\n  return [{\n    json: {\n      ...input,\n      action: 'nurture',\n      replyMessage: \"Thanks for reaching out! Could you tell me a bit more about your current fitness goals?\",\n      error: e.message\n    }\n  }];\n}"
      },
